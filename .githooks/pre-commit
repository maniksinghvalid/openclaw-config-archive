#!/bin/sh
# Block commits with obvious secrets
if git diff --cached --name-only -z | xargs -0 grep -lE 'PAT|ghp_[a-zA-Z0-9]+|glpat-[a-zA-Z0-9-]+|slack_api_token|Bearer [a-zA-Z0-9]+' >/dev/null; then
    echo "❌ ERROR: Potential secret detected in staged files!"
    echo "Please remove secrets before committing."
    exit 1
fi
